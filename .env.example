# 复制此文件为 .env.dev 或 .env.prod 并填写。
# .env 文件无需手动创建，项目已内置。

# === 环境配置 ===
DRIVER=~fastapi+~httpx
HOST=127.0.0.1
PORT=8080
SUPERUSERS=[] # 可选，默认空列表，用于设置超级用户
LOG_LEVEL=INFO          # TRACE / DEBUG / INFO / WARNING / ERROR
COMMAND_START=["/", ""]

# === get_seer_info 插件 ===
# 设置 SYNC_URL 后从远程自动拉取并定时更新；留空则从本地文件加载，不自动更新。
SEERAPI_SYNC_URL=https://github.com/SeerAPI/api-data/releases/download/latest/seerapi-data.sqlite
SEERAPI_SYNC_INTERVAL_MINUTES=60       # 可选，默认 60，同步间隔（分钟）
SEERAPI_LOCAL_PATH=seerapi-data.sqlite  # 可选，SYNC_URL 为空时的本地回退路径
ALIAS_SYNC_URL=https://github.com/SeerAPI/api-data/releases/download/latest/aliases-data.sqlite
ALIAS_SYNC_INTERVAL_MINUTES=60         # 可选，默认 60，同步间隔（分钟）
ALIAS_LOCAL_PATH=aliases-data.sqlite    # 可选，SYNC_URL 为空时的本地回退路径

# === 表情包插件，当缺少必填项时相关命令将被禁用 ===
MEMES_CNB_TOKEN=              # CNB API 令牌（敏感，必填）
MEMES_CNB_REPO=Nattsu39/tudou # CNB 仓库路径可选，默认 Nattsu39/tudou
# MEMES=["tudou","pig"]  # 可选，默认全部启用，表示启用哪些表情包命令

# === 无头赛尔号客户端配置，部分功能需要登录无头客户端获取数据 ===
HEADLESS_SEER_USER_ID=12345678   # 米米号
HEADLESS_SEER_PASSWORD=...  # 密码（明文密码的MD5值）
HEADLESS_SEER_HEARTBEAT_INTERVAL=300  # 心跳间隔（秒）